<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:models="clr-namespace:Sentinel.Models"
             xmlns:viewModels="clr-namespace:Sentinel.ViewModels"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="Sentinel.Views.HomeView"
             x:DataType="viewModels:HomeViewModel">
    <StackPanel>
        <StackPanel Orientation="Horizontal">
            <TextBlock VerticalAlignment="Center">
                Filtre :  
            </TextBlock>
            <TextBox Text="{Binding FilterText}" />
        </StackPanel>
        <StackPanel Orientation="Horizontal">
            <DataGrid ItemsSource="{Binding FilteredUnits}" IsReadOnly="True" CanUserSortColumns="True"
                      SelectedItem="{Binding SelectedUnit}">
                <DataGrid.Columns>
                    <DataGridTextColumn Binding="{Binding Name, DataType=viewModels:EquipmentUnitViewModel}"
                                        Header="Nom" />
                    <DataGridTextColumn Binding="{Binding Zone, DataType=viewModels:EquipmentUnitViewModel}"
                                        Header="Zone" />
                    <DataGridTextColumn Binding="{Binding Status, DataType=viewModels:EquipmentUnitViewModel}"
                                        Header="Statut" />
                    <DataGridTextColumn Binding="{Binding Battery, DataType=viewModels:EquipmentUnitViewModel, StringFormat='{}{0:0.0}%'}"
                                        Header="Batt. %" />
                    <DataGridTextColumn Binding="{Binding Temperature, DataType=viewModels:EquipmentUnitViewModel, StringFormat='{}{0:0.0}°C'}"
                                        Header="Temp. °C" />
                    <DataGridTextColumn Binding="{Binding Signal, DataType=viewModels:EquipmentUnitViewModel, StringFormat='{}{0}%'}"
                                        Header="Signal %" />
                    <DataGridTextColumn Binding="{Binding LastSeen, DataType=viewModels:EquipmentUnitViewModel, StringFormat='dd/MM/yy H:mm:ss'}"
                                        Header="Vu à" />
                </DataGrid.Columns>
            </DataGrid>
            <Border>
                <Panel>
                    <TextBlock Text="Sélectionnez une unité dans la grille"
                               IsVisible="{Binding !HasSelection}" />
                    <StackPanel IsVisible="{Binding HasSelection}">
                        <TextBlock Text="{Binding SelectedUnit?.Name}"
                                   FontWeight="Bold" />
                        <TextBlock Text="{Binding SelectedUnit?.Zone}"
                                   Foreground="Gray" />
                    
                        <TextBlock Text="Télémétrie (live)"
                                   FontWeight="Bold" />
                        <TextBlock Text="{Binding SelectedUnit?.Status, StringFormat='{}Statut : {0}'}" />
                        <TextBlock Text="{Binding SelectedUnit?.Battery, StringFormat='{}Batterie : {0:0.0} %'}" />
                        <TextBlock Text="{Binding SelectedUnit?.Temperature, StringFormat='{}Température : {0:0.0} °C'}" />
                        <TextBlock Text="{Binding SelectedUnit?.Signal, StringFormat='{}Signal : {0} %'}" />
                        <TextBlock Text="{Binding SelectedUnit?.LastSeen, StringFormat='{}Vu à : {0:H:mm:ss}'}"
                                   Foreground="Gray"/>
                        
                        <TextBlock Text="Editer"
                                   FontWeight="Bold" />
                        <TextBlock Text="Nom" />
                        <TextBox Text="{Binding EditViewModel?.Name, Mode=TwoWay}" />
                        <TextBlock Text="Zone" />
                        <TextBox Text="{Binding EditViewModel?.Zone, Mode=TwoWay}" />
                        <Button Command="{Binding SaveCommand}" HorizontalAlignment="Right">
                            Enregistrer
                        </Button>
                    </StackPanel>
                </Panel>
            </Border>
        </StackPanel>
    </StackPanel>
</UserControl>
